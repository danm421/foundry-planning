# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# turborepo
**/.turbo

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# worktrees
.worktrees/

# private reference docs (never committed)
docs/private/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — broad catch-all. `.env*` covers .env, .env.local, .env.*.local,
# and stray backups like `.env.local.bak.<date>` (the 2026-06-09 billing audit
# found one such file holding live secrets — finding #6). The negation keeps the
# committed template visible.
.env*
!.env.example

# backup files (e.g. *.bak left by editors / manual env snapshots)
*.bak

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# clerk configuration (can include secrets)
/.clerk/

# Claude Code local harness state (session settings, transcripts)
.claude/
.claire/

# Local-only scripts — filename convention for tools that connect to a
# live database or otherwise shouldn't run in CI. Mirrors the .env.local
# pattern above. Committed versions live next to them without the
# `.local` suffix. Covers any extension (.ts/.mjs/.js) plus local state
# files like saved Playwright auth (scripts/.<name>.local.json).
scripts/*.local.*
scripts/.backfill-securities.checkpoint.json
scripts/.backfill-securities.checkpoint.json.tmp

# Generated report output (e.g. CMA recompute diff)
scripts/output/

# Sentry Config File
.env.sentry-build-plugin
.env*.local

# Brainstorming visual companion
.superpowers/

# Expo mobile app (mobile/)
mobile/.expo/
mobile/ios/
mobile/android/
mobile/.env
