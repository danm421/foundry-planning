# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/clients
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/clients

# Clerk Webhook (organization.created → auto-seed CMAs)
# Obtain from Clerk dashboard → Webhooks → your endpoint → Signing Secret.
# Required in preview/prod; optional in local dev (webhook can't reach localhost
# without an ngrok/tunnel setup — Layer 3 lazy seed covers dev).
CLERK_WEBHOOK_SECRET=whsec_...

# Neon Database
DATABASE_URL=postgresql://...@...neon.tech/foundry-planning?sslmode=require

# Azure OpenAI — document extraction
AZURE_API_KEY=
AZURE_ENDPOINT=
AZURE_API_VERSION=2024-12-01-preview
AZURE_MODEL=gpt-5.4-mini
AZURE_ANALYSIS_MODEL=gpt-5.4

# Upstash Redis — rate limiting (required; extract endpoint fails closed without it)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# EODHD — holdings price quotes (real-time EOD close) + nightly price-refresh cron.
# Obtain from https://eodhd.com → Settings → API token.
# Required for holdings prices to resolve; without it every quote fails soft to
# null (the holdings search box shows null). Also used by scripts/seed-securities*.
# Set here AND in Vercel env (preview + prod) — the cron runs in prod.
EODHD_API_KEY=

# Stripe — billing (Phase 4/5). Test-mode keys for Dev/Preview, live-mode for
# Production. The SDK accepts an rk_test_/rk_live_ RESTRICTED key identically to
# an sk_ key — Production uses a non-expiring rk_live_ (see go-live runbook).
#   Dev/Preview: sk_test_… or rk_test_…   |   Production: rk_live_…
STRIPE_SECRET_KEY=
# Webhook signing secret for /api/webhooks/stripe. DISTINCT per mode and per
# endpoint — the test-mode `stripe listen` whsec_… differs from the live
# Dashboard endpoint's whsec_… . Production = the LIVE endpoint's secret.
STRIPE_WEBHOOK_SECRET=
# Price IDs (price_…). Test-mode and live-mode IDs are DIFFERENT objects; set
# test IDs in Dev/Preview and live IDs in Production. See
# docs/stripe-price-setup-checklist.md for the four prices + nicknames.
STRIPE_PRICE_ID_SEAT_MONTHLY=
STRIPE_PRICE_ID_SEAT_ANNUAL=
STRIPE_PRICE_ID_SEAT_FOUNDING_ANNUAL=
STRIPE_PRICE_ID_AI_IMPORT_MONTHLY=

# Resend — billing notifications (failed-payment, trial-ending, 3DS-required).
# Obtain RESEND_API_KEY from https://resend.com → API Keys. BILLING_EMAIL_FROM
# must be an address on a domain VERIFIED in Resend (e.g. billing@foundryplanning.com).
# Same key works test+live; Resend distinguishes by verified-domain, not mode.
RESEND_API_KEY=
BILLING_EMAIL_FROM=

# Inbox that receives in-app support + feedback submissions (defaults to
# support@foundryplanning.com). The Resend sender defaults to a support-branded
# address on the verified foundryplanning.com domain; set SUPPORT_EMAIL_FROM to
# override it (e.g. "Foundry Support <support@foundryplanning.com>").
SUPPORT_EMAIL=support@foundryplanning.com
SUPPORT_EMAIL_FROM=

# Cron auth — Vercel Cron injects `Authorization: Bearer $CRON_SECRET`. Each
# cron route fails closed without it (reconcile-billing, purge-expired-firms,
# refresh-holding-prices). Use one strong random value per environment.
CRON_SECRET=

# Public app origin — used to build Checkout success/cancel URLs and the
# Customer Portal return_url. No trailing slash. Falls back to
# https://app.foundryplanning.com when unset.
#   Local: http://localhost:3000   |   Production: https://app.foundryplanning.com
NEXT_PUBLIC_APP_URL=
